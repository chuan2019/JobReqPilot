# =============================================================================
# JobReqPilot — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# -----------------------------------------------------------------------------
# Ollama (local LLM inference server)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://ollama:11434
# OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_LLM_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# -----------------------------------------------------------------------------
# Redis (result & embedding cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------
# Tavily API key for job board searches
# Get a key at https://tavily.com/
TAVILY_API_KEY=

# -----------------------------------------------------------------------------
# MCP Server URLs (internal Docker network addresses)
# -----------------------------------------------------------------------------
MCP_JOB_SEARCH_URL=http://mcp-job-search:8001
MCP_SUMMARIZE_URL=http://mcp-summarize:8002

# -----------------------------------------------------------------------------
# Backend
# -----------------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
