# =============================================================================
# Backend — Environment Variables
# In Docker Compose these are injected from the root .env file.
# This file documents the variables the backend code expects.
# =============================================================================

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_LLM_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=nomic-embed-text

REDIS_URL=redis://redis:6379/0

TAVILY_API_KEY=

MCP_JOB_SEARCH_URL=http://mcp-job-search:8001
MCP_SUMMARIZE_URL=http://mcp-summarize:8002

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info
